# ===========================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE
# Copie para .env e preencha com valores reais
# ===========================================

# Database
DATABASE_URL=postgresql://usuario:senha@localhost:5432/c0ntrol

# Node Environment
NODE_ENV=production

# Application
PORT=3000
HOSTNAME=0.0.0.0

# Security (adicione no futuro)
JWT_SECRET=seu_secret_super_seguro_aqui
SESSION_SECRET=outra_chave_secreta_aqui

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
